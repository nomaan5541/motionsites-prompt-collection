yer.style.maskImage = 'url(' + dataUrl + ')';\r\n    imgLayer.style.webkitMaskSize = '100% 100%';\r\n    imgLayer.style.maskSize = '100% 100%';\r\n\r\n    requestAnimationFrame(loop);\r\n  }\r\n  requestAnimationFrame(loop);\r\n})();\r\n</script>\r\n</body>\r\n</html>",
